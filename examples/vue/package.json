{
  "name": "vue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "mkdir -p public && cp ../../packages/@wterm/core/wasm/wterm.wasm public/wterm.wasm && chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null; (command -v portless >/dev/null 2>&1 || (echo '\\nportless is required but not installed. Run: npm i -g portless\\nSee: https://github.com/vercel-labs/portless\\n' && exit 1))",
    "dev": "portless vue-example.wterm vite",
    "prebuild": "mkdir -p public && cp ../../packages/@wterm/core/wasm/wterm.wasm public/wterm.wasm",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@wterm/core": "workspace:*",
    "@wterm/dom": "workspace:*",
    "@wterm/just-bash": "workspace:*",
    "@wterm/vue": "workspace:*",
    "just-bash": "^2.14.2",
    "node-pty": "^1.0.0",
    "vue": "^3.5.32",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6"
  }
}
