{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["svelte", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "*.d.ts",
    "svelte.config.js",
    "vite.config.ts",
    "vite-plugins/**/*.ts"
  ]
}
