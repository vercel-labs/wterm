{
  "name": "markdown-streaming",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "command -v portless >/dev/null 2>&1 || (echo '\\nportless is required but not installed. Run: npm i -g portless\\nSee: https://github.com/vercel-labs/portless\\n' && exit 1)",
    "dev": "portless markdown-streaming-example.wterm next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@wterm/core": "workspace:*",
    "@wterm/dom": "workspace:*",
    "@wterm/markdown": "workspace:*",
    "@wterm/react": "workspace:*",
    "ai": "^5.0.0",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2"
  }
}
