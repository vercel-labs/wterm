{
  "name": "@wterm/core",
  "version": "0.1.8",
  "description": "Headless terminal emulator core for the web — WASM bridge and WebSocket transport",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./wasm": "./wasm/wterm.wasm"
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "prebuild": "node scripts/inline-wasm.js",
    "build": "tsc",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@internal/ts": "workspace:*",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "terminal",
    "emulator",
    "wasm",
    "zig",
    "xterm"
  ],
  "license": "Apache-2.0",
  "homepage": "https://wterm.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel-labs/wterm",
    "directory": "packages/@wterm/core"
  }
}
